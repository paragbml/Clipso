NODE_ENV=development
PORT=8080
DATABASE_URL="postgresql://clipso:clipso@localhost:5432/clipso?schema=public"
# Optional in free-mode deployment. Leave blank to use in-memory queue.
REDIS_URL=""
RUN_INLINE_WORKER=false
METRICS_REFRESH_CRON="*/15 * * * *"
ENABLE_MOCK_CRAWLER=true

# Optional platform credentials
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
X_BEARER_TOKEN=
