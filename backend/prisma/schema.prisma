generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIPPER
  CREATOR
  ADMIN
}

enum CampaignStatus {
  DRAFT
  LIVE
  PAUSED
  COMPLETED
}

enum SubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE_SHORTS
  TWITCH
  X
  OTHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns   Campaign[]   @relation("CreatorCampaigns")
  submissions Submission[] @relation("ClipperSubmissions")
}

model Campaign {
  id          String         @id @default(cuid())
  creatorId   String
  title       String
  description String?
  budgetCents Int
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator     User          @relation("CreatorCampaigns", fields: [creatorId], references: [id], onDelete: Cascade)
  submissions Submission[]
  stats       CampaignStats?

  @@index([creatorId, status])
}

model Submission {
  id          String           @id @default(cuid())
  campaignId  String
  clipperId   String
  sourceUrl   String
  platform    Platform
  caption     String?
  status      SubmissionStatus @default(PENDING_REVIEW)
  payoutCents Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clipper     User          @relation("ClipperSubmissions", fields: [clipperId], references: [id], onDelete: Cascade)
  socialPosts SocialPost[]
  stats       SubmissionStats?

  @@index([clipperId, status])
  @@index([campaignId, status])
}

model SocialPost {
  id             String   @id @default(cuid())
  submissionId   String
  platform       Platform
  externalPostId String
  postUrl        String
  handle         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submission    Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  metricSamples MetricSample[]

  @@unique([platform, externalPostId])
  @@index([submissionId])
}

model MetricSample {
  id              String   @id @default(cuid())
  socialPostId    String
  views           Int
  likes           Int
  comments        Int
  shares          Int
  saves           Int
  watchTimeSecond Int?
  fetchedAt       DateTime @default(now())

  socialPost SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)

  @@index([socialPostId, fetchedAt])
}

model SubmissionStats {
  submissionId    String   @id
  latestViews     Int      @default(0)
  latestLikes     Int      @default(0)
  latestComments  Int      @default(0)
  latestShares    Int      @default(0)
  latestSaves     Int      @default(0)
  engagementRate  Float    @default(0)
  viewsDelta24h   Int      @default(0)
  totalEarnings   Int      @default(0)
  updatedAt       DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model CampaignStats {
  campaignId         String   @id
  totalViews         Int      @default(0)
  totalLikes         Int      @default(0)
  totalComments      Int      @default(0)
  totalShares        Int      @default(0)
  totalSubmissions   Int      @default(0)
  avgEngagementRate  Float    @default(0)
  updatedAt          DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
